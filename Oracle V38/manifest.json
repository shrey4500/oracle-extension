{
  "manifest_version": 3,
  "name": "Oracle",
  "version": "1.2",
  "description": "AI-powered Chrome extension with real-time push notifications",
  "icons": {
    "16": "icon-oracle.png",
    "32": "icon-oracle.png",
    "48": "icon-oracle.png",
    "128": "icon-oracle.png"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "contextMenus",
    "notifications",
    "scripting",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "https://n8n-kqq5.onrender.com/*",
    "https://realtime.ably.io/*",
    "https://rest.ably.io/*",
    "wss://realtime.ably.io/*",
    "https://*.ably.com/*"
  ],
  "action": {
    "default_title": "Oracle",
    "default_icon": {
      "16": "icon-oracle.png",
      "32": "icon-oracle.png",
      "48": "icon-oracle.png",
      "128": "icon-oracle.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icon-slack.png",
        "icon-gmail.png",
        "icon-drive.png",
        "icon-zoom.png",
        "icon-google-meet.png",
        "icon-google-calendar.png",
        "icon-freshdesk.png",
        "icon-freshrelease.png",
        "icon-freshservice.png",
        "icon-google-docs.png",
        "icon-google-sheets.png",
        "icon-google-slides.png"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
